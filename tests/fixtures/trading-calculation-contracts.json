    {
      "id": "fifo_partial_exits",
      "description": "FIFO partial exits prorate entry costs into each realized exit.",
      "input": {
        "side": "long",
        "instrumentType": "stock",
        "timezone": "UTC",
        "executions": [
          { "action": "buy", "quantity": 100, "price": 10, "commission": 1, "fees": 0.1, "datetime": "2026-01-09T10:00:00Z" },
          { "action": "sell", "quantity": 40, "price": 11, "commission": 0.4, "fees": 0.04, "datetime": "2026-01-09T11:00:00Z" },
          { "action": "sell", "quantity": 60, "price": 12, "commission": 0.6, "fees": 0.06, "datetime": "2026-01-09T14:00:00Z" }
        ]
      },
      "expected": {
        "aggregate": {
          "entry_price": 10,
          "exit_price": 11.6,
          "quantity": 100,
          "commission": 2,
          "fees": 0.2,
          "pnl": 157.8,
          "pnl_percent": 15.78,
          "is_fully_closed": true
        },
        "realized_pnl": [null, 39.12, 118.68]
      }
    },
    {
      "id": "grouped_executions",
      "description": "Grouped execution records calculate weighted entry and exit averages.",
      "input": {
        "side": "long",
        "instrumentType": "stock",
        "timezone": "UTC",
        "executions": [
          { "entryPrice": 100, "exitPrice": 110, "quantity": 10, "commission": 1, "fees": 0.2, "entryTime": "2026-01-10T10:00:00Z", "exitTime": "2026-01-10T13:00:00Z" },
          { "entryPrice": 102, "exitPrice": 108, "quantity": 5, "commission": 0.5, "fees": 0.1, "entryTime": "2026-01-10T10:05:00Z", "exitTime": "2026-01-10T13:05:00Z" }
        ]
      },
      "expected": {
        "aggregate": {
          "entry_price": 100.6666666667,
          "exit_price": 109.3333333333,
          "quantity": 15,
          "commission": 1.5,
          "fees": 0.3,
          "pnl": 128.2,
          "pnl_percent": 8.4900662252,
          "is_fully_closed": true
        },
        "realized_pnl": [98.8, 29.4]
      }
    },
