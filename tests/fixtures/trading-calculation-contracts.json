{
  "pnl_engine_cases": [
    {
      "id": "stock_long_round_trip",
      "description": "Long stock trade deducts entry and exit costs from gross price P&L.",
      "input": {
        "side": "long",
        "instrumentType": "stock",
        "timezone": "UTC",
        "executions": [
          { "action": "buy", "quantity": 100, "price": 10, "commission": 1, "fees": 0, "datetime": "2026-01-05T10:00:00Z" },
          { "action": "sell", "quantity": 100, "price": 12, "commission": 1, "fees": 0.25, "datetime": "2026-01-05T14:00:00Z" }
        ]
      },
      "expected": {
        "aggregate": {
          "entry_price": 10,
          "exit_price": 12,
          "quantity": 100,
          "commission": 2,
          "fees": 0.25,
          "pnl": 197.75,
          "pnl_percent": 19.775,
          "is_fully_closed": true
        },
        "realized_pnl": [null, 197.75]
      }
    },
    {
      "id": "stock_short_round_trip",
      "description": "Short stock trade uses entry minus exit for gross price P&L.",
      "input": {
        "side": "short",
        "instrumentType": "stock",
        "timezone": "UTC",
        "executions": [
          { "action": "sell", "quantity": 50, "price": 20, "commission": 0.5, "fees": 0, "datetime": "2026-01-06T10:00:00Z" },
          { "action": "buy", "quantity": 50, "price": 18, "commission": 0.5, "fees": 0.1, "datetime": "2026-01-06T14:00:00Z" }
        ]
      },
      "expected": {
        "aggregate": {
          "entry_price": 20,
          "exit_price": 18,
          "quantity": 50,
          "commission": 1,
          "fees": 0.1,
          "pnl": 98.9,
          "pnl_percent": 9.89,
          "is_fully_closed": true
        },
        "realized_pnl": [null, 98.9]
      }
    },
